# =====================
# Cloudflare Pages / LIFF 用の環境変数サンプル
# このファイルを .env にコピーして使用してください
# =====================

# Google Apps Script Web App 設定（Cloudflare Pages Functions用）
# GAS Web App の deploy URL
# GAS_BASE_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# GAS との通信に使う API キー
# GAS_API_KEY="your-random-secret-key"

# LIFF 設定（Cloudflare Pages Functions用）
# LINE Developers Console で発行した LIFF ID
# LIFF_ID="1234567890-abcdefgh"

# デプロイ環境名（Cloudflare Pages Functions の /api/config で返却）
# ENVIRONMENT_NAME="production"
